import objetos.*

describe "test de futbol" {
    method initialize() {
        game.width(15)
	    game.height(10)
    }

    test "inicio" {
        assert.notEquals(game.at(0,5), pelota.position())
        pelota.irAlInicio()
        assert.equals(game.at(0,5), pelota.position())
    }

    test "buscarla" {
        assert.notEquals(lionel.position(), pelota.position())
        lionel.buscarla()
        assert.equals(lionel.position(), pelota.position())
    }
}